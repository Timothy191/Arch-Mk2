# ── PostgreSQL (local data store — for ops queries / backups) ─────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=coal_mine
POSTGRES_PORT=5432

# ── Redis (caching, rate-limiting, queues) ────────────────────────────────────
REDIS_PORT=6379

# ── Ports ────────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
PORTAL_PORT=3000
API_PORT=3001
OPS_GATEWAY_PORT=3100

# ── API Configuration ────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:80,http://192.168.0.52:3000
TRUST_PROXY=true
DISABLE_RATE_LIMIT=false
INTERNAL_API_SECRET=arch-production-internal-secret

# ── AI / Ollama (local LLM on host machine) ──────────────────────────────────
OLLAMA_URL=http://host.docker.internal:5243

# ── SurrealDB (optional — AI memory system) ──────────────────────────────────
