# ──────────────────────────────────────────────────────────────────────────────
# Arch-Mk2 Production Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# PURPOSE: Production environment variables for the full Docker Compose stack.
#
# USAGE:
#   1. Copy this file to .env.production
#      cp .env.production.example .env.production
#   2. Edit .env.production with your actual values
#   3. Deploy: ./scripts/deploy-production.sh
#
# WARNING: Never commit the actual .env.production file with real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required: Supabase (database + auth) ──────────────────────────────────────
# Get these from your Supabase project dashboard:
#   Project Settings → API → Project URL, anon key, service_role key
# For self-hosted Supabase, use your local Supabase URLs:
#   supabase start → http://localhost:54321
#
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Required: PostgreSQL (local data store) ───────────────────────────────────
# These are the credentials for the local PostgreSQL container.
# Defaults work for development; change for production.
#
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres          # CHANGE THIS in production!
POSTGRES_DB=coal_mine
POSTGRES_PORT=5432

# ── Required: Redis (caching, rate-limiting, queues) ─────────────────────────
# Default port is 6379. Service auto-connects via Docker networking.
#
REDIS_PORT=6379

# ── Ports ────────────────────────────────────────────────────────────────────
# Exposed ports for external access. Change if conflicts occur.
#
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
PORTAL_PORT=3000
API_PORT=3001
OPS_GATEWAY_PORT=3100

# ── API Configuration ────────────────────────────────────────────────────────
# CORS origin should match the URL users access the portal from.
#
CORS_ORIGIN=http://localhost:80
TRUST_PROXY=true
DISABLE_RATE_LIMIT=false
INTERNAL_API_SECRET=change-this-secret

# ── AI / Ollama (optional — local LLM for AI features) ───────────────────────
# If Ollama is running on the host machine (outside Docker),
# use: OLLAMA_URL=http://host.docker.internal:5243
# If Ollama is in a separate container, use the container name.
#
OLLAMA_URL=http://host.docker.internal:5243

# ── SurrealDB (optional — AI memory system) ──────────────────────────────────
SURREALDB_URL=
SURREALDB_NS=plantcor
SURREALDB_DB=ai
SURREALDB_USER=root
SURREALDB_PASS=root

# ── Sentry (optional — error monitoring) ────────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ── OpenTelemetry (optional — observability) ──────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── External Tools (optional) ───────────────────────────────────────────────
# NEXT_PUBLIC_FUXA_URL=http://localhost:1881
# NEXT_PUBLIC_HIGHLIGHT_PROJECT_ID=
