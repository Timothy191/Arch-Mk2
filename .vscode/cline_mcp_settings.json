{
  "mcpServers": {
    "preflight-mcp": {
      "command": "node",
      "args": [
        "tools/preflight-mcp/index.js"
      ]
    },
    "n8n-mcp": {
      "command": "node",
      "args": [
        "tools/n8n-mcp/index.js"
      ],
      "env": {
        "N8N_URL": "http://localhost:5678",
        "N8N_EMAIL": "your-n8n-email-here",
        "N8N_PASSWORD": "your-n8n-password-here"
      }
    },
    "codebase-memory": {
      "command": "codebase-memory-mcp",
      "args": []
    },
    "repowise-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "tools/repowise",
        "repowise",
        "mcp",
        ".",
        "--transport",
        "stdio"
      ]
    },
    "sense-mcp": {
      "command": "tools/sense/bin/sense",
      "args": []
    },
    "memex-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "tools/memex",
        "memex",
        "serve"
      ],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "memex-local",
        "GEMINI_API_KEY": "your-gemini-api-key-here"
      }
    }
  }
}
